<idea-plugin>
    <id>fr.tjiba.claude.commit</id>
    <name>Claude Commit Message</name>
    <vendor email="contact@tjiba.fr">Tjiba</vendor>

    <description>Generates concise, context-aware Git commit messages from your selected changes using Anthropic's Claude AI. Supports local Claude and API modes with customizable prompts.</description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                id="claude.commit.settings"
                displayName="Claude Commit"
                parentId="tools"
                instance="fr.tjiba.claudecommit.settings.ClaudeCommitConfigurable"/>
        <notificationGroup id="Claude Commit Notifications" displayType="BALLOON" isLogByDefault="true"/>
    </extensions>

    <actions resource-bundle="claudeCommitBundle">
        <action id="ClaudeCommit.GenerateMessage"
                class="fr.tjiba.claudecommit.actions.GenerateCommitMessageAction"
                icon="/icons/claudeCommit.svg"
                text="Generate Claude Commit Message"
                description="%action.generate.description">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
            <add-to-group group-id="VcsGroup" anchor="last"/>
        </action>
    </actions>
</idea-plugin>