<idea-plugin>
    <resource-bundle>claudeCommitBundle</resource-bundle>
    <id>fr.tjiba.claude.commit</id>
    <name>%plugin.name</name>
    <vendor email="tjiba@tjiba.fr">Tjiba</vendor>

    <description>
        %plugin.description
    </description>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                id="claude.commit.settings"
                displayName="%settings.display.name"
                parentId="tools"
                instance="fr.tjiba.claudecommit.settings.ClaudeCommitConfigurable"/>
        <notificationGroup id="Claude Commit Notifications" displayType="BALLOON" isLogByDefault="true"/>
    </extensions>

    <actions>
        <action id="ClaudeCommit.GenerateMessage"
                class="fr.tjiba.claudecommit.actions.GenerateCommitMessageAction"
                icon="/icons/claudeCommit.svg"
                text="%action.generate.text"
                description="%action.generate.description">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="first"/>
            <add-to-group group-id="ChangesView.CommitMessageEditorToolbar" anchor="first"/>
            <add-to-group group-id="VcsGroup" anchor="last"/>
        </action>
    </actions>
</idea-plugin>